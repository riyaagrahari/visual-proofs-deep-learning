# Generated training/evaluation artifacts (reproducible from data/ + scripts/)

# Python
__pycache__/
*.pyc
.pytest_cache/

# User-provided corpus data is real text, not code -- keep folder
# structure (.gitkeep) but never commit actual corpus files by accident.

# OS
.DS_Store

# build cache / local corpus backup
*.tsbuildinfo
data/_corpus_backup/

# Large, regenerable raw Wikipedia HTML (tools/build_corpus.py); only the
# faithful .txt/.md snapshots are committed for reproducibility.
corpus/*.raw.html
# Scratch training output (authoritative copies live in backend/artifacts/).
tools/out/
